{
  "server": {
    "port": "8090",
    "read_timeout": "5s",
    "write_timeout": "10s",
    "idle_timeout": "2m",
    "rate_limit_enabled": false,
    "cors": {
      "allowed_origins": ["*"],
      "allowed_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allowed_headers": ["Content-Type", "Authorization", "X-API-Key"],
      "max_age": 86400
    },
    "public_routes": [
      "GET /health/healthcheck",
      "GET /uploads/*",
      "GET /devices/status"
    ],
    "auth_routes": [
      "GET /auth/me"
    ],
    "admin_routes": [
      "GET /devices/*",
      "POST /devices/*",
      "PUT /devices/*",
      "DELETE /devices/*",
      "POST /commands/device/*"
    ],
    "device_lenient_routes": [
      "GET /commands/pending"
    ]
  },
  "oauth": {
    "type": "google",
    "audience": ""
  },
  "storage": {
    "type": "gcs",
    "options": {
      "bucket": "birdhouse-uploads"
    }
  },
  "database": {
    "type": "postgres",
    "options": {
      "name": "birdhouse",
      "user": "postgres",
      "host": "127.0.0.1",
      "port": "5432",
      "ssl_mode": "disable",
      "connection_timeout": 30,
      "pool_min_connections": "1",
      "pool_max_connections": "10",
      "pool_max_conn_life": "5m",
      "pool_max_conn_idle": "1m",
      "pool_health_check": "1m"
    }
  },
  "mqtt": {
    "broker_url": "tcp://localhost:1883",
    "client_id": "birdhouse-api",
    "username": ""
  },
  "ai": {
    "type": "anthropic",
    "options": {
      "api_url": "https://api.anthropic.com/v1/messages",
      "model": "claude-sonnet-4-20250514",
      "timeout": "30s"
    }
  }
}
